# ---------------------------------------------------------------------------
# Display the cat based on mood or action
# ---------------------------------------------------------------------------
show_cat() {
    local display_mood="${1:-$MOOD}"
    case "${display_mood}" in
        ecstatic)  ascii_cat_ecstatic ;;
        happy)     ascii_cat_happy ;;
        okay)      ascii_cat_okay ;;
        sad)       ascii_cat_sad ;;
        miserable) ascii_cat_miserable ;;
        sleeping)  ascii_cat_sleeping ;;
        eating)    ascii_cat_eating ;;
        playing)   ascii_cat_playing ;;
        dead)      ascii_cat_dead ;;
        *)         ascii_cat_happy ;;
    esac
}

# ---------------------------------------------------------------------------
# Stat bar renderer
# ---------------------------------------------------------------------------
stat_bar() {
    local label="$1"
    local value="$2"
    local max=100
    local bar_width=20
    local filled=$(( value * bar_width / max ))
    local empty=$(( bar_width - filled ))

    local color
    if (( value >= 70 )); then
        color="${GREEN}"
    elif (( value >= 40 )); then
        color="${YELLOW}"
    else
        color="${RED}"
    fi

    printf "  %-11s ${color}" "${label}:"
    printf "["
    for (( i=0; i<filled; i++ )); do printf "#"; done
    for (( i=0; i<empty; i++ )); do printf "."; done
    printf "] %3d%%${RESET}\n" "${value}"
}

# ---------------------------------------------------------------------------
# Show full status panel
# ---------------------------------------------------------------------------
show_status() {
    load_state
    decay_stats

    echo ""
    echo -e "${BOLD}${WHITE}  ========= SSH Buddy =========${RESET}"
    echo -e "  ${BOLD}Name:${RESET} ${PET_NAME}  ${DIM}(${PET_TYPE})${RESET}"
    echo -e "  ${BOLD}Age:${RESET}  ${AGE_DAYS} day(s)"
    echo -e "  ${BOLD}Mood:${RESET} ${MOOD}"
    echo -e "${BOLD}${WHITE}  ==============================${RESET}"
    echo ""

    show_cat

    stat_bar "Hunger" "${HUNGER}"
    stat_bar "Energy" "${ENERGY}"
    stat_bar "Happiness" "${HAPPINESS}"
    stat_bar "Health" "${HEALTH}"

    echo ""
    echo -e "  ${DIM}Lifetime - Feeds: ${TOTAL_FEEDS} | Plays: ${TOTAL_PLAYS} | Naps: ${TOTAL_SLEEPS}${RESET}"
    echo ""

    if (( ALIVE == 0 )); then
        echo -e "  ${RED}${BOLD}Your buddy has passed away from neglect...${RESET}"
        echo -e "  ${DIM}Use 'sshb revive' to bring them back.${RESET}"
        echo ""
    fi
}

# ---------------------------------------------------------------------------
# Animated action display
# ---------------------------------------------------------------------------
animate_action() {
    local action="$1"
    local frames=3
    local delay=0.5

    for (( f=0; f<frames; f++ )); do
        clear
        echo ""
        echo -e "${BOLD}${WHITE}  === SSH Buddy - ${action} ===${RESET}"
        echo ""
        case "${action}" in
            Feeding)
                if (( f % 2 == 0 )); then
                    ascii_cat_eating
                else
                    ascii_cat_happy
                fi
                ;;
            Playing)
                if (( f % 2 == 0 )); then
                    ascii_cat_playing
                else
                    ascii_cat_ecstatic
                fi
                ;;
            Sleeping)
                ascii_cat_sleeping
                local zs=""
                for (( z=0; z<=f; z++ )); do zs="${zs}z"; done
                echo -e "  ${BLUE}${zs}...${RESET}"
                ;;
        esac
        sleep "${delay}"
    done
}

# ---------------------------------------------------------------------------
# Feed the pet
# ---------------------------------------------------------------------------
cmd_feed() {
    load_state
    decay_stats

    if (( ALIVE == 0 )); then
        echo -e "${RED}Your buddy is no longer with us. Use 'sshb revive' first.${RESET}"
        return 1
    fi

    if (( IS_SLEEPING == 1 )); then
        echo -e "${YELLOW}${PET_NAME} is sleeping. Let them rest or use 'sshb wake' first.${RESET}"
        return 1
    fi

    if (( HUNGER >= 95 )); then
        echo -e "${YELLOW}${PET_NAME} is already full! No need to feed right now.${RESET}"
        show_cat "happy"
        return 0
    fi

    animate_action "Feeding"

    local gain=$(( RANDOM % 15 + 20 ))
    HUNGER=$(clamp $(( HUNGER + gain )))
    HAPPINESS=$(clamp $(( HAPPINESS + 5 )))
    HEALTH=$(calc_health)
    MOOD=$(calc_mood)
    LAST_FED_EPOCH=$(date +%s)
    TOTAL_FEEDS=$(( TOTAL_FEEDS + 1 ))
    save_state

    clear
    echo ""
    echo -e "${GREEN}${BOLD}  Yum! ${PET_NAME} enjoyed the meal! (+${gain} hunger)${RESET}"
    echo ""
    show_cat
    stat_bar "Hunger" "${HUNGER}"
    stat_bar "Happiness" "${HAPPINESS}"
    echo ""
}

# ---------------------------------------------------------------------------
# Play with the pet
# ---------------------------------------------------------------------------
cmd_play() {
    load_state
    decay_stats

    if (( ALIVE == 0 )); then
        echo -e "${RED}Your buddy is no longer with us. Use 'sshb revive' first.${RESET}"
        return 1
    fi

    if (( IS_SLEEPING == 1 )); then
        echo -e "${YELLOW}${PET_NAME} is sleeping. Let them rest or use 'sshb wake' first.${RESET}"
        return 1
    fi

    if (( ENERGY < 10 )); then
        echo -e "${YELLOW}${PET_NAME} is too tired to play. Try 'sshb sleep' first.${RESET}"
        show_cat "sad"
        return 1
    fi

    animate_action "Playing"

    local gain=$(( RANDOM % 15 + 20 ))
    HAPPINESS=$(clamp $(( HAPPINESS + gain )))
    ENERGY=$(clamp $(( ENERGY - 10 )))
    HUNGER=$(clamp $(( HUNGER - 5 )))
    HEALTH=$(calc_health)
    MOOD=$(calc_mood)
    LAST_PLAYED_EPOCH=$(date +%s)
    TOTAL_PLAYS=$(( TOTAL_PLAYS + 1 ))
    save_state

    clear
    echo ""
    echo -e "${MAGENTA}${BOLD}  ${PET_NAME} had a blast playing! (+${gain} happiness)${RESET}"
    echo ""
    show_cat
    stat_bar "Happiness" "${HAPPINESS}"
    stat_bar "Energy" "${ENERGY}"
    echo ""
}

# ---------------------------------------------------------------------------
# Put the pet to sleep
# ---------------------------------------------------------------------------
cmd_sleep() {
    load_state
    decay_stats

    if (( ALIVE == 0 )); then
        echo -e "${RED}Your buddy is no longer with us. Use 'sshb revive' first.${RESET}"
        return 1
    fi

    if (( IS_SLEEPING == 1 )); then
        echo -e "${BLUE}${PET_NAME} is already sleeping. Shhh...${RESET}"
        show_cat "sleeping"
        return 0
    fi

    if (( ENERGY >= 95 )); then
        echo -e "${YELLOW}${PET_NAME} is wide awake and not tired at all!${RESET}"
        show_cat "happy"
        return 0
    fi

    animate_action "Sleeping"

    IS_SLEEPING=1
    MOOD="sleeping"
    LAST_SLEPT_EPOCH=$(date +%s)
    TOTAL_SLEEPS=$(( TOTAL_SLEEPS + 1 ))
    save_state

    clear
    echo ""
    echo -e "${BLUE}${BOLD}  ${PET_NAME} curled up and fell asleep. Sweet dreams!${RESET}"
    echo ""
    show_cat "sleeping"
    stat_bar "Energy" "${ENERGY}"
    echo ""
    echo -e "  ${DIM}Energy will restore over time while sleeping.${RESET}"
    echo ""
}

# ---------------------------------------------------------------------------
# Wake the pet up
# ---------------------------------------------------------------------------
cmd_wake() {
    load_state
    decay_stats

    if (( IS_SLEEPING == 0 )); then
        echo -e "${YELLOW}${PET_NAME} is already awake!${RESET}"
        return 0
    fi

    IS_SLEEPING=0
    MOOD=$(calc_mood)
    save_state

    echo ""
    echo -e "${CYAN}${BOLD}  ${PET_NAME} woke up!${RESET}"
    echo ""
    show_cat
    stat_bar "Energy" "${ENERGY}"
    echo ""
}

# ---------------------------------------------------------------------------
# Rename the pet
# ---------------------------------------------------------------------------
cmd_rename() {
    local new_name="$1"
    if [[ -z "${new_name}" ]]; then
        echo -e "${YELLOW}Usage: sshb rename <new-name>${RESET}"
        return 1
    fi

    # Sanitize - only allow alphanumeric, spaces, hyphens, underscores
    new_name=$(echo "${new_name}" | tr -cd 'a-zA-Z0-9 _-')

    if [[ -z "${new_name}" ]]; then
        echo -e "${RED}Invalid name. Use letters, numbers, spaces, hyphens, or underscores.${RESET}"
        return 1
    fi

    load_state
    local old_name="${PET_NAME}"
    PET_NAME="${new_name}"
    save_state

    echo -e "${GREEN}Renamed your buddy from '${old_name}' to '${PET_NAME}'!${RESET}"
}

# ---------------------------------------------------------------------------
# Revive a dead pet (reset stats)
# ---------------------------------------------------------------------------
cmd_revive() {
    load_state

    if (( ALIVE == 1 )); then
        echo -e "${YELLOW}${PET_NAME} is alive and well! No need to revive.${RESET}"
        return 0
    fi

    HUNGER=50
    ENERGY=50
    HAPPINESS=50
    HEALTH=50
    ALIVE=1
    IS_SLEEPING=0
    MOOD="happy"
    local now
    now=$(date +%s)
    LAST_FED_EPOCH=${now}
    LAST_SLEPT_EPOCH=${now}
    LAST_PLAYED_EPOCH=${now}
    LAST_UPDATE_EPOCH=${now}
    save_state

    echo ""
    echo -e "${GREEN}${BOLD}  ${PET_NAME} has been revived! Welcome back, buddy!${RESET}"
    echo ""
    show_cat "happy"
    echo ""
}

# ---------------------------------------------------------------------------
# Reset everything (new pet)
# ---------------------------------------------------------------------------
cmd_reset() {
    echo -e "${YELLOW}This will completely reset your pet. Are you sure? (y/n)${RESET}"
    read -r confirm
    if [[ "${confirm}" == "y" || "${confirm}" == "Y" ]]; then
        rm -f "${STATE_FILE}"
        load_state
        echo -e "${GREEN}New buddy created! Say hello to ${PET_NAME}!${RESET}"
        show_cat "happy"
    else
        echo "Reset cancelled."
    fi
}

# ---------------------------------------------------------------------------
# One-line status for prompt integration
# ---------------------------------------------------------------------------
cmd_prompt() {
    load_state
    decay_stats

    if (( ALIVE == 0 )); then
        echo -e "[${PET_NAME}:x.x]"
        return
    fi

    local icon
    case "${MOOD}" in
        ecstatic)  icon="^o^" ;;
        happy)     icon="^.^" ;;
        okay)      icon="-.-" ;;
        sad)       icon="T.T" ;;
        miserable) icon=";_;" ;;
        sleeping)  icon="-_- z" ;;
        *)         icon="..." ;;
    esac

    local avg=$(( (HUNGER + ENERGY + HAPPINESS) / 3 ))
    local color
    if (( avg >= 70 )); then
        color="${GREEN}"
    elif (( avg >= 40 )); then
        color="${YELLOW}"
    else
        color="${RED}"
    fi

    echo -e "${color}[${PET_NAME}(${icon}) H:${HUNGER} E:${ENERGY} J:${HAPPINESS}]${RESET}"
}

# ---------------------------------------------------------------------------
# Mini display - compact status for quick checks
# ---------------------------------------------------------------------------
cmd_mini() {
    load_state
    decay_stats

    show_cat
    echo -e "  ${BOLD}${PET_NAME}${RESET} - ${MOOD}"
    echo -e "  H:${HUNGER}% E:${ENERGY}% J:${HAPPINESS}%"
    echo ""
}

# ---------------------------------------------------------------------------
# Interactive mode
# ---------------------------------------------------------------------------
cmd_interactive() {
    while true; do
        clear
        show_status

        echo -e "  ${BOLD}Commands:${RESET}"
        echo -e "    ${CYAN}f${RESET} - Feed    ${CYAN}p${RESET} - Play    ${CYAN}s${RESET} - Sleep"
        echo -e "    ${CYAN}w${RESET} - Wake    ${CYAN}r${RESET} - Refresh ${CYAN}q${RESET} - Quit"
        echo ""
        echo -n "  > "
        read -r -n 1 choice
        echo ""

        case "${choice}" in
            f) cmd_feed ;;
            p) cmd_play ;;
            s) cmd_sleep ;;
            w) cmd_wake ;;
            r) continue ;;
            q) clear; echo -e "${CYAN}See you later! ${PET_NAME} will be waiting.${RESET}"; break ;;
            *) echo -e "${YELLOW}Unknown command.${RESET}"; sleep 1 ;;
        esac

        if [[ "${choice}" != "r" && "${choice}" != "q" ]]; then
            echo ""
            echo -e "  ${DIM}Press any key to continue...${RESET}"
            read -r -n 1
        fi
    done
}

