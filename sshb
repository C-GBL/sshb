# ---------------------------------------------------------------------------
# Install prompt integration
# ---------------------------------------------------------------------------
cmd_install_prompt() {
    local bashrc="${HOME}/.bashrc"
    local marker="# SSHB-PROMPT-INTEGRATION"

    if grep -q "${marker}" "${bashrc}" 2>/dev/null; then
        echo -e "${YELLOW}SSH Buddy prompt is already installed in your .bashrc${RESET}"
        return 0
    fi

    cat >> "${bashrc}" << 'BASHEOF'

# SSHB-PROMPT-INTEGRATION - SSH Buddy Tamagotchi prompt
# This updates your prompt with your pet's status every time you hit Enter
if command -v sshb &> /dev/null; then
    __sshb_prompt() {
        local sshb_status
        sshb_status=$(sshb prompt 2>/dev/null)
        if [[ -n "${sshb_status}" ]]; then
            PS1="${sshb_status} \[\033[1;32m\]\u@\h\[\033[0m\]:\[\033[1;34m\]\w\[\033[0m\]\$ "
        else
            PS1="\[\033[1;32m\]\u@\h\[\033[0m\]:\[\033[1;34m\]\w\[\033[0m\]\$ "
        fi
    }
    PROMPT_COMMAND="__sshb_prompt"
fi
# END-SSHB-PROMPT-INTEGRATION
BASHEOF

    echo -e "${GREEN}SSH Buddy prompt installed! Run 'source ~/.bashrc' or open a new terminal.${RESET}"
    echo -e "${DIM}Your prompt will now show ${PET_NAME}'s status.${RESET}"
}

# ---------------------------------------------------------------------------
# Uninstall prompt integration
# ---------------------------------------------------------------------------
cmd_uninstall_prompt() {
    local bashrc="${HOME}/.bashrc"
    local start_marker="# SSHB-PROMPT-INTEGRATION"
    local end_marker="# END-SSHB-PROMPT-INTEGRATION"

    if ! grep -q "${start_marker}" "${bashrc}" 2>/dev/null; then
        echo -e "${YELLOW}SSH Buddy prompt is not installed in your .bashrc${RESET}"
        return 0
    fi

    sed -i "/${start_marker}/,/${end_marker}/d" "${bashrc}"
    echo -e "${GREEN}SSH Buddy prompt removed. Run 'source ~/.bashrc' or open a new terminal.${RESET}"
}

# ---------------------------------------------------------------------------
# Version
# ---------------------------------------------------------------------------
cmd_version() {
    echo -e "sshb v${VERSION}"
}

# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------
main() {
    init_dir
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "${cmd}" in
        feed)              cmd_feed ;;
        play)              cmd_play ;;
        sleep)             cmd_sleep ;;
        wake)              cmd_wake ;;
        status|"")         show_status ;;
        mini)              cmd_mini ;;
        prompt)            cmd_prompt ;;
        interactive|i)     cmd_interactive ;;
        rename)            cmd_rename "$*" ;;
        revive)            cmd_revive ;;
        reset)             cmd_reset ;;
        install-prompt)    load_state; cmd_install_prompt ;;
        uninstall-prompt)  cmd_uninstall_prompt ;;
        version|-v)        cmd_version ;;
        help|-h|--help)    cmd_help ;;
        *)
            echo -e "${RED}Unknown command: ${cmd}${RESET}"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
